# Ports exposed on the host machine.
GENAI_HOST_PORT=8002
FRONTEND_HOST_PORT=8090
FRONTEND_DEV_HOST_PORT=5173
APP_HOST_PORT=8081
APP_DATABASE_POSTGRES_PORT=5432
CHAT_DATABASE_API_PORT=8083
CHAT_DATABASE_POSTGRES_PORT=5431
CADDY_HTTP_PORT=8088
OLLAMA_PORT=11434

# Local Ollama is the default provider. Set to openai to use OPENAI_BASE_URL instead.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:4b
# 8192 accommodates the MCP tool schemas, Sudoku board, and model response.
OLLAMA_CONTEXT_LENGTH=8192
OPENAI_BASE_URL=https://logos.aet.cit.tum.de:8080/v1
OPENAI_MODEL=openai/gpt-oss-120b

# Production domain used by the Caddy image in docker-compose.prod.yaml.
# Example: DOMAIN=example.com
DOMAIN=example.com

# Container image tag used by docker-compose.yaml. For prod latest should not be used.
IMAGE_TAG=latest

# Application database
APP_DATABASE_NAME=game_database
APP_DATABASE_USER=app_user

# Chat database service
CHAT_DATABASE_NAME=chat_database
CHAT_DATABASE_USER=chat_user

# Spring runtime profile used inside Docker Compose
CHAT_DATABASE_SPRING_PROFILE=docker

# Supabase JWT verification key set. Used by the application and chat services.
SUPABASE_AUTH_JWKS_URI=https://pwjnldzqwwagnxjycfaq.supabase.co/auth/v1/.well-known/jwks.json

# Docker Compose secret file.
# Create this file locally, for example with secretctl and secrets/secret.manifest.toml.
# Do not commit the generated secret file.
APP_DATABASE_PASSWORD_FILE=./secrets/app_database_password
CHAT_DATABASE_PASSWORD_FILE=./secrets/chat_database_password
LOGOS_KEY_FILE=./secrets/logos_key
